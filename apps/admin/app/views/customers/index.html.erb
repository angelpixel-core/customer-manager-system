<%= render DesignSystem::UI::Organisms::PanelComponent.new(title: "Create Customer") do %>
  <%= form_with url: admin_customers_path, method: :post do %>
    <%= render DesignSystem::UI::Atoms::InputComponent.new(
      name: :name,
      label: "Name",
      placeholder: "Jane Doe"
    ) %>

    <%= render DesignSystem::UI::Atoms::InputComponent.new(
      name: :email,
      label: "Email",
      type: :email,
      placeholder: "jane@example.com"
    ) %>

    <%= render DesignSystem::UI::Atoms::ButtonComponent.new(
      label: "Create customer",
      variant: :primary,
      type: :submit
    ) %>
  <% end %>
<% end %>

<%= render DesignSystem::UI::Organisms::PanelComponent.new(title: "Latest Customers") do %>
  <% if @customers.empty? %>
    <p>No customers yet.</p>
  <% else %>
    <ul role="list" class="u-mt-sm">
      <% @customers.each do |customer| %>
        <li class="u-mb-sm"><strong><%= customer.name %></strong> - <%= customer.email %></li>
      <% end %>
    </ul>
  <% end %>
<% end %>
