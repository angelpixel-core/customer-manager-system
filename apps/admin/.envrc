export ENV_PROFILE="${ENV_PROFILE:-dev}"

load_env_file() {
  if [ -f "$1" ]; then
    dotenv "$1"
  fi
}

load_env_file "platform/environments/local/env/${ENV_PROFILE}/db.env"
load_env_file "platform/environments/local/env/${ENV_PROFILE}/worker.env"
load_env_file "platform/environments/local/env/${ENV_PROFILE}/app.env"

export PROJECT_DB_PREFIX="${PROJECT_DB_PREFIX:-customers_manager_system}"
export DATABASE_URL="${DATABASE_URL:-postgres://postgres:postgres@localhost:${POSTGRES_PORT:-5433}/${PROJECT_DB_PREFIX}_development}"
export FAKTORY_URL="${FAKTORY_URL:-tcp://localhost:7419}"
